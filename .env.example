# Apple Developer Account Configuration for Code Signing and Notarization
# Copy this file to .env and fill in your values
# Do NOT commit .env to git - it contains sensitive credentials

APPLE_ID=your-apple-id@example.com
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (XXXXXXXXXX)

# PowerMac G4 SSH Configuration (OS X 10.5 Leopard)
# Used for remote PPC builds and development
PPC_SSH_HOST=192.168.x.x
PPC_SSH_USER=me
PPC_SSH_PASSWORD=your-password
